{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "include": ["src/**/*", "examples/**/*"],
  "exclude": ["node_modules/*", "public/*"],
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "/src/*": ["src/*"],
      "/examples/*": ["examples/*"]
    },
    "module": "esnext",
    "moduleResolution": "node",
    "types": ["svelte", "vite/dist/importMeta"]
  }
}
